@page
@using System.Linq
@model SportWearShop.Web.Pages.Products.IndexModel

@{
    ViewData["Title"] = "Products";

    var products = Model.Products?.Items
        ?? Enumerable.Empty<SportWearShop.Shared.ViewModels.ProductModels.ProductResponseModel>();

    var currentPage = Model.Products?.PageNumber ?? Model.Query.PageNumber;
    var pageSize = Model.Products?.PageSize ?? Model.Query.PageSize;
    var totalPages = Model.Products?.TotalPages ?? 1;
    var totalRecords = Model.Products?.TotalCount ?? products.Count();
}

<section class="shop-page-section">
    <div class="container py-5">

        <div class="card border-0 shadow-sm rounded-4 mb-5">
            <div class="card-body p-4 p-md-5">
                @if (Model.SelectedBrand is not null)
                {
                    <span class="text-uppercase text-muted small fw-semibold">
                        Brand Collection
                    </span>

                    <h2 class="mt-2 mb-3 text-uppercase">
                        @Model.SelectedBrand.BrandName Collection
                        @* <span class="fs-6 text-muted">(@totalRecords)</span> *@
                    </h2>

                    <p class="text-muted mb-0">
                        Browse all @Model.SelectedBrand.BrandName products available in SportWearShop.
                    </p>
                }
                else
                {
                    <span class="text-uppercase text-muted small fw-semibold">
                        SportWearShop Collection
                    </span>

                    <h2 class="mt-2 mb-3">
                        Performance sportwear and everyday essentials.
                    </h2>

                    <p class="text-muted mb-0">
                        Discover products designed for training, movement, and daily comfort.
                    </p>
                }
            </div>
        </div>

        <div class="row g-4">

            <!-- LEFT: FILTER -->
            <div class="col-12 col-lg-3">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4">Filter Products</h5>

                        <form method="get">

                            <input type="hidden" asp-for="Query.PageNumber" value="1" />
                            <input type="hidden" asp-for="Query.PageSize" />

                            <div class="mb-3">
                                <label asp-for="Query.SearchTerm" class="form-label">
                                    Search
                                </label>
                                <input asp-for="Query.SearchTerm"
                                       class="form-control"
                                       placeholder="Product name, code..." />
                            </div>
                            <!-- BRAND -->
                            <div class="mb-3">
                                <label class="form-label fw-semibold">
                                    Brand
                                    @if (Model.SelectedBrand is not null)
                                    {
                                        <span>(1)</span>
                                    }
                                </label>

                                <div class="form-check mb-2">
                                    <input class="form-check-input"
                                        type="radio"
                                        name="Query.BrandIds"
                                        value=""
                                        id="brand-all"
                                        checked="@(Model.Query.BrandIds?.Any() != true)" />

                                    <label class="form-check-label" for="brand-all">
                                        All Brands
                                    </label>
                                </div>

                                @foreach (var brand in Model.Brands)
                                {
                                    var isChecked = Model.Query.BrandIds?.FirstOrDefault() == brand.BrandId;

                                    <div class="form-check mb-2">
                                        <input class="form-check-input"
                                            type="radio"
                                            name="Query.BrandIds"
                                            value="@brand.BrandId"
                                            id="brand-@brand.BrandId"
                                            checked="@isChecked" />

                                        <label class="form-check-label d-flex justify-content-between"
                                            for="brand-@brand.BrandId">
                                            <span>@brand.BrandName</span>
                                        </label>
                                    </div>
                                }
                            </div>

                            <div class="mb-3">
                                <label asp-for="Query.Gender" class="form-label">
                                    Gender
                                </label>
                                <select asp-for="Query.Gender" class="form-select">
                                    <option value="">All Genders</option>
                                    <option value="0">Unisex</option>
                                    <option value="1">Men</option>
                                    <option value="2">Woman</option>
                                    <option value="3">Kids</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Query.IsOnSale" class="form-label">
                                    Sale Status
                                </label>
                                <select asp-for="Query.IsOnSale" class="form-select">
                                    <option value="">All Products</option>
                                    <option value="true">On Sale</option>
                                    <option value="false">Not On Sale</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Query.IsNewRelease" class="form-label">
                                    Release
                                </label>
                                <select asp-for="Query.IsNewRelease" class="form-select">
                                    <option value="">All Releases</option>
                                    <option value="true">New Release</option>
                                    <option value="false">Normal</option>
                                </select>
                            </div>

                            <div class="row">
                                <div class="col-6 mb-3">
                                    <label asp-for="Query.MinPrice" class="form-label">
                                        Min Price
                                    </label>
                                    <input asp-for="Query.MinPrice"
                                           type="number"
                                           step="1000"
                                           class="form-control"
                                           placeholder="0" />
                                </div>

                                <div class="col-6 mb-3">
                                    <label asp-for="Query.MaxPrice" class="form-label">
                                        Max Price
                                    </label>
                                    <input asp-for="Query.MaxPrice"
                                           type="number"
                                           step="1000"
                                           class="form-control"
                                           placeholder="999999" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Query.SortBy" class="form-label">
                                    Sort By
                                </label>
                                <select asp-for="Query.SortBy" class="form-select">
                                    <option value="1">Created Date</option>
                                    <option value="2">Updated Date</option>
                                    <option value="3">Product Name</option>
                                    <option value="4">Product Code</option>
                                    <option value="5">Brand</option>
                                    <option value="6">Category</option>
                                    <option value="7">Price</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <label asp-for="Query.IsAscending" class="form-label">
                                    Order
                                </label>
                                <select asp-for="Query.IsAscending" class="form-select">
                                    <option value="false">Descending</option>
                                    <option value="true">Ascending</option>
                                </select>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-dark">
                                    Filter
                                </button>

                                <a asp-page="/Products/Index"
                                   class="btn btn-outline-secondary">
                                    Clear
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- RIGHT: PRODUCT GRID -->
            <div class="col-12 col-lg-9">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="mb-1">Products</h2>
                        <p class="text-muted mb-0">
                            Browse all available sportwear products.
                        </p>
                    </div>
                </div>

                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge rounded-pill text-bg-dark px-3 py-2">
                            Total: @totalRecords
                        </span>

                        <span class="badge rounded-pill text-bg-light border px-3 py-2">
                            Page @currentPage / @totalPages
                        </span>
                    </div>

                    <div class="text-muted">
                        Showing @products.Count() product(s)
                    </div>
                </div>

                <div class="row g-4">
                    @if (products.Any())
                    {
                        foreach (var product in products)
                        {
                            <div class="col-12 col-sm-6 col-xl-4">
                                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">

                                    <div class="position-relative bg-light" style="min-height: 240px;">
                                        @if (!string.IsNullOrWhiteSpace(product.ThumbnailUrl))
                                        {
                                            <img src="@product.ThumbnailUrl"
                                                 alt="@product.ProductName"
                                                 class="w-100 h-100"
                                                 style="object-fit: cover; min-height: 240px;" />
                                        }
                                        else
                                        {
                                            <div class="d-flex justify-content-center align-items-center text-center h-100 p-4"
                                                 style="min-height: 240px;">
                                                <div>
                                                    <p class="text-muted mb-2">@product.CategoryName</p>
                                                    <h6 class="fw-semibold mb-0">@product.ProductName</h6>
                                                </div>
                                            </div>
                                        }

                                        @if (product.MinSalePrice.HasValue)
                                        {
                                            <span class="badge text-bg-danger position-absolute top-0 start-0 m-3">
                                                Sale
                                            </span>
                                        }

                                        <span class="badge text-bg-light border position-absolute top-0 end-0 m-3">
                                            @product.Gender
                                        </span>
                                    </div>

                                    <div class="card-body d-flex flex-column">
                                        <p class="text-uppercase text-muted small mb-2">
                                            @product.BrandName · @product.CategoryName
                                        </p>

                                        <h5 class="card-title mb-2">
                                            @product.ProductName
                                        </h5>

                                        <p class="text-muted small mb-3">
                                            Code: @product.ProductCode
                                        </p>

                                        <div class="mb-3">
                                            @if (product.MinSalePrice.HasValue)
                                            {
                                                <span class="fw-bold fs-5 text-danger">
                                                    @product.MinSalePrice.Value.ToString("N0") ₫
                                                </span>

                                                <span class="text-muted text-decoration-line-through ms-2">
                                                    @product.MinPrice.ToString("N0") ₫
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="fw-bold fs-5">
                                                    @product.MinPrice.ToString("N0") ₫
                                                </span>
                                            }
                                        </div>

                                        <div class="mt-auto">
                                            <a asp-page="/Products/Details"
                                                asp-route-productId="@product.ProductId"
                                                class="btn btn-dark w-100 rounded-3">
                                                    View Product Details
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="alert alert-light border rounded-4 mb-0">
                                No products found with the selected filters.
                            </div>
                        </div>
                    }
                </div>

                @if (totalPages > 1)
                {
                    <nav class="mt-4 d-flex justify-content-center" aria-label="Shop pagination">
                        <ul class="pagination">

                            <li class="page-item @(currentPage <= 1 ? "disabled" : "")">
                                <a class="page-link"
                                    asp-page="/Products/Index"
                                    asp-route-Query.PageNumber="@(currentPage - 1)"
                                    asp-route-Query.PageSize="@pageSize"
                                    asp-route-Query.SearchTerm="@Model.Query.SearchTerm"
                                    asp-route-Query.Gender="@Model.Query.Gender"
                                    asp-route-Query.IsOnSale="@Model.Query.IsOnSale"
                                    asp-route-Query.IsNewRelease="@Model.Query.IsNewRelease"
                                    asp-route-Query.MinPrice="@Model.Query.MinPrice"
                                    asp-route-Query.MaxPrice="@Model.Query.MaxPrice"
                                    asp-route-Query.SortBy="@Model.Query.SortBy"
                                    asp-route-Query.IsAscending="@Model.Query.IsAscending"
                                    asp-route-Query.BrandIds="@(Model.Query.BrandIds?.FirstOrDefault())">
                                    Previous
                                </a>
                            </li>

                            @for (var i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link"
                                       asp-page="/Products/Index"
                                       asp-route-Query.PageNumber="@i"
                                       asp-route-Query.PageSize="@pageSize"
                                       asp-route-Query.SearchTerm="@Model.Query.SearchTerm"
                                       asp-route-Query.Gender="@Model.Query.Gender"
                                       asp-route-Query.IsOnSale="@Model.Query.IsOnSale"
                                       asp-route-Query.IsNewRelease="@Model.Query.IsNewRelease"
                                       asp-route-Query.MinPrice="@Model.Query.MinPrice"
                                       asp-route-Query.MaxPrice="@Model.Query.MaxPrice"
                                       asp-route-Query.SortBy="@Model.Query.SortBy"
                                       asp-route-Query.IsAscending="@Model.Query.IsAscending">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(currentPage >= totalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-page="/Products/Index"
                                   asp-route-Query.PageNumber="@(currentPage + 1)"
                                   asp-route-Query.PageSize="@pageSize"
                                   asp-route-Query.SearchTerm="@Model.Query.SearchTerm"
                                   asp-route-Query.Gender="@Model.Query.Gender"
                                   asp-route-Query.IsOnSale="@Model.Query.IsOnSale"
                                   asp-route-Query.IsNewRelease="@Model.Query.IsNewRelease"
                                   asp-route-Query.MinPrice="@Model.Query.MinPrice"
                                   asp-route-Query.MaxPrice="@Model.Query.MaxPrice"
                                   asp-route-Query.SortBy="@Model.Query.SortBy"
                                   asp-route-Query.IsAscending="@Model.Query.IsAscending">
                                    Next
                                </a>
                            </li>

                        </ul>
                    </nav>
                }
            </div>
        </div>


    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ToastMessage))
{
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="productToast"
             class="toast align-items-center text-bg-@Model.ToastType border-0"
             role="alert">
            <div class="d-flex">
                <div class="toast-body">
                    @Model.ToastMessage
                </div>
                <button type="button"
                        class="btn-close btn-close-white me-2 m-auto"
                        data-bs-dismiss="toast">
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const toastElement = document.getElementById("productToast");
            const toast = new bootstrap.Toast(toastElement, {
                delay: 4000
            });

            toast.show();
        });
    </script>
}