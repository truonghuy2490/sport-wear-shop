@page
@model SportWearShop.Web.Pages.Auth.LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="d-flex align-items-center justify-content-center py-5"
     style="min-height: 70vh;">

    <div class="col-12 col-sm-10 col-md-7 col-lg-5">

        <div class="card border-0 shadow-sm rounded-4" style="border-radius: 24px;">
            <div class="card-body p-4 p-lg-5">

                <div class="text-center mb-4">

                    <h1 class="fw-bold mb-2">
                        Welcome Back
                    </h1>

                    <p class="text-muted mb-0">
                        Login to continue shopping.
                    </p>

                </div>

                <div asp-validation-summary="ModelOnly"
                    class="text-danger small mb-3">
                </div>

                <form 
                    method="post" 
                    style="
                        border-radius: 14px;
                        padding: 0.85rem 1rem;
                    ">
                        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
                        {
                            <div class="alert alert-danger py-2 small mb-4">
                                @Model.ErrorMessage
                            </div>
                        }

                        <div class="mb-3">

                            <label asp-for="Input.Email"
                                class="form-label fw-medium">
                            </label>

                            <input asp-for="Input.Email"
                                class="form-control form-control-lg" />

                            <span asp-validation-for="Input.Email"
                                class="text-danger small">
                            </span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Input.Password"
                                class="form-label fw-medium">
                            </label>

                            <input asp-for="Input.Password"
                                type="password"
                                class="form-control form-control-lg" />

                            <span asp-validation-for="Input.Password"
                                class="text-danger small">
                            </span>

                        </div>

                        <button type="submit"
                                class="btn btn-dark btn-lg w-100"
                                style="border-radius: 14px;">
                            Login
                        </button>

                </form>

                <div class="text-center mt-4">

                    <span class="text-muted">
                        Don't have an account?
                    </span>

                    <a asp-page="/Auth/Register"
                       class="text-dark fw-semibold text-decoration-none">
                        Register
                    </a>

                </div>

            </div>
        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}