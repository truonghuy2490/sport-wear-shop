@page
@model SportWearShop.Web.Pages.Errors.UnauthorizedModel

@{
    ViewData["Title"] = "Unauthorized";
}

<div class="text-center py-5">
    <h1 class="display-5">401</h1>
    <h2>Please login first</h2>
    <p class="text-muted">You need to login before accessing this page.</p>

    <a asp-page="/Auth/Login" class="btn btn-primary">
        Go to Login
    </a>
</div>